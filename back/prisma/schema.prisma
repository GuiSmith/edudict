generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model migrations {
  nome_arquivo String   @id @db.VarChar(200)
  executada_em DateTime @default(now()) @db.Timestamp(6)
}

model usuario {
  id       Int        @id @default(autoincrement())
  nome     String     @db.VarChar(150)
  cpf      String     @unique @db.Char(11)
  email    String     @unique @db.VarChar(150)
  senha    String
  ativo    Boolean    @default(true)
  chat     chat[]
  log_api  log_api[]
  log_app  log_app[]
  predicao predicao[]
  tokens   token[]
}

model token {
  id         Int      @id @default(autoincrement())
  token      String   @unique
  id_usuario Int
  ativo      Boolean  @default(true)
  criado_em  DateTime @default(now()) @db.Timestamp(6)
  usuario    usuario  @relation(fields: [id_usuario], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model log_api {
  id               BigInt   @id @default(autoincrement())
  data_hora        DateTime @default(dbgenerated("LOCALTIMESTAMP")) @db.Timestamp(6)
  metodo           String   @db.VarChar(10)
  rota             String
  url_original     String?
  status_code      Int      @db.SmallInt
  ip               String?  @db.Inet
  user_agent       String?
  referer          String?
  params           Json?
  query            Json?
  body             Json?
  response_body    Json?
  response_time_ms Int
  id_usuario       Int?
  erro             Boolean  @default(false)
  erro_mensagem    String?
  usuario          usuario? @relation(fields: [id_usuario], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model log_app {
  id         BigInt   @id @default(autoincrement())
  id_usuario Int?
  data_hora  DateTime @default(dbgenerated("LOCALTIMESTAMP")) @db.Timestamp(6)
  tabela     String   @db.VarChar(100)
  id_tabela  BigInt?
  operacao   String   @db.VarChar(10)
  antes      Json?
  depois     Json?
  usuario    usuario? @relation(fields: [id_usuario], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model predicao {
  id                 Int      @id @default(autoincrement())
  id_usuario         Int?
  guest_session_id   String?  @db.Uuid
  school             String   @db.VarChar(2)
  sex                String   @db.VarChar(1)
  age                Int
  address            String   @db.VarChar(1)
  famsize            String   @db.VarChar(3)
  Pstatus            String   @db.VarChar(1)
  Medu               Int
  Fedu               Int
  Mjob               String   @db.VarChar(20)
  Fjob               String   @db.VarChar(20)
  reason             String   @db.VarChar(20)
  guardian           String   @db.VarChar(20)
  traveltime         Int
  studytime          Int
  failures           Int
  schoolsup          String   @db.VarChar(3)
  famsup             String   @db.VarChar(3)
  paid               String   @db.VarChar(3)
  activities         String   @db.VarChar(3)
  nursery            String   @db.VarChar(3)
  higher             String   @db.VarChar(3)
  internet           String   @db.VarChar(3)
  romantic           String   @db.VarChar(3)
  famrel             Int
  freetime           Int
  goout              Int
  Dalc               Int
  Walc               Int
  health             Int
  absences           Int
  subject            String   @db.VarChar(20)
  aprovado           Boolean
  resultado_predicao Json
  interpretacao_llm  String?
  data_hora_criacao  DateTime @default(now()) @db.Timestamp(6)
  chat               chat[]
  usuario            usuario? @relation(fields: [id_usuario], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model chat {
  id                    Int             @id @default(autoincrement())
  id_usuario            Int?
  guest_session_id      String?         @db.Uuid
  id_predicao           Int?
  titulo                String?         @db.VarChar(25)
  data_hora_criacao     DateTime        @default(now()) @db.Timestamp(6)
  data_hora_atualizacao DateTime        @default(now()) @db.Timestamp(6)
  predicao              predicao?       @relation(fields: [id_predicao], references: [id], onDelete: NoAction, onUpdate: NoAction)
  usuario               usuario?        @relation(fields: [id_usuario], references: [id], onDelete: NoAction, onUpdate: NoAction)
  chat_mensagem         chat_mensagem[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model chat_mensagem {
  id                Int      @id @default(autoincrement())
  id_chat           Int
  role              String   @db.VarChar(20)
  content           String
  tokens_prompt     Int?
  tokens_completion Int?
  data_hora         DateTime @default(now()) @db.Timestamp(6)
  chat              chat     @relation(fields: [id_chat], references: [id], onDelete: Cascade, onUpdate: NoAction)
}
