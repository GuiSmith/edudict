generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model migrations {
  nome_arquivo String   @id @db.VarChar(200)
  executada_em DateTime @default(now()) @db.Timestamp(6)
}

model usuario {
  id      Int       @id @default(autoincrement())
  nome    String    @db.VarChar(150)
  cpf     String    @unique @db.Char(11)
  email   String    @unique @db.VarChar(150)
  senha   String
  ativo   Boolean   @default(true)
  log_api log_api[]
  log_app log_app[]
  tokens  token[]
}

model token {
  id         Int      @id @default(autoincrement())
  token      String   @unique
  id_usuario Int
  ativo      Boolean  @default(true)
  criado_em  DateTime @default(now()) @db.Timestamp(6)
  usuario    usuario  @relation(fields: [id_usuario], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model log_api {
  id               BigInt   @id @default(autoincrement())
  data_hora        DateTime @default(dbgenerated("LOCALTIMESTAMP")) @db.Timestamp(6)
  metodo           String   @db.VarChar(10)
  rota             String
  url_original     String?
  status_code      Int      @db.SmallInt
  ip               String?  @db.Inet
  user_agent       String?
  referer          String?
  params           Json?
  query            Json?
  body             Json?
  response_body    Json?
  response_time_ms Int
  id_usuario       Int?
  erro             Boolean  @default(false)
  erro_mensagem    String?
  usuario          usuario? @relation(fields: [id_usuario], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model log_app {
  id         BigInt   @id @default(autoincrement())
  id_usuario Int?
  data_hora  DateTime @default(dbgenerated("LOCALTIMESTAMP")) @db.Timestamp(6)
  tabela     String   @db.VarChar(100)
  id_tabela  BigInt?
  operacao   String   @db.VarChar(10)
  antes      Json?
  depois     Json?
  usuario    usuario? @relation(fields: [id_usuario], references: [id], onDelete: NoAction, onUpdate: NoAction)
}
